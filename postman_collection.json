    {
      "name": "3. 预约模块 (Bookings)",
      "item": [
        {
          "name": "3.1 创建预约",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api", "bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomId\": 2,\n  \"bookingDate\": \"{{$timestamp}}\",\n  \"startTime\": \"14:00:00\",\n  \"endTime\": \"16:00:00\",\n  \"purpose\": \"日常钢琴练习\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate() + 1);",
                  "var dateStr = tomorrow.toISOString().split('T')[0];",
                  "pm.request.body.raw = pm.request.body.raw.replace('\"{{$timestamp}}\"', '\"' + dateStr + '\"');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"创建预约 - 状态码200\", function () { pm.response.to.have.status(200); });",
                  "if (pm.response.json().code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set(\"bookingId\", json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3.2 获取预约列表",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bookings?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"获取预约列表 - 状态码200\", function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3.3 获取我的预约",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings/mine", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "mine"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"获取我的预约 - 状态码200\", function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3.4 获取预约详情",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings/1", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "1"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"获取预约详情 - 状态码200\", function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3.5 修改预约状态",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings/2/status", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "2", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"修改预约状态 - 状态码200\", function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
