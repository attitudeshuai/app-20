        {
          "name": "4.4 签出操作",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/checkins/1", "host": ["{{baseUrl}}"], "path": ["api", "checkins", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkOut\": true,\n  \"note\": \"练习结束，设备正常\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
