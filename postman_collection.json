              "raw": "{{baseUrl}}/api/practicerooms?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "practicerooms"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
