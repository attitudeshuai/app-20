{
  "info": {
    "name": "乐器练习室预约管理系统 API 测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "覆盖所有接口的功能测试集合，包括认证、练习室、预约、签到、反馈、统计等模块"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8090"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "roomId",
      "value": "1"
    },
    {
      "key": "bookingId",
      "value": "1"
    },
    {
      "key": "checkInId",
      "value": "1"
    },
    {
      "key": "issueId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "1. 认证模块 (Auth)",
      "item": [
        {
          "name": "1.1 用户注册 - 新用户",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser001\",\n  \"email\": \"test001@example.com\",\n  \"password\": \"password123\",\n  \"avatar\": \"https://api.dicebear.com/7.x/avataaars/svg?seed=test001\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"注册成功 - 状态码200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"注册成功 - 返回code 200\", function () { var json = pm.response.json(); pm.expect(json.code).to.eql(200); });",
                  "pm.test(\"注册成功 - 包含token\", function () { var json = pm.response.json(); pm.expect(json.data.token).to.exist; });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "1.2 用户注册 - 用户名重复(预期失败)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"zhangsan\",\n  \"email\": \"unique@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"用户名重复 - 返回code 400\", function () { var json = pm.response.json(); pm.expect(json.code).to.not.eql(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "1.3 管理员登录",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"管理员登录成功 - 状态码200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"管理员登录成功 - 返回code 200\", function () { var json = pm.response.json(); pm.expect(json.code).to.eql(200); });",
                  "pm.test(\"管理员登录成功 - 保存token\", function () { var json = pm.response.json(); pm.collectionVariables.set(\"adminToken\", json.data.token); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "1.4 普通用户登录",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"zhangsan\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"普通用户登录成功 - 状态码200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"普通用户登录成功 - 保存token\", function () { var json = pm.response.json(); pm.collectionVariables.set(\"userToken\", json.data.token); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "1.5 错误密码登录(预期401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"zhangsan\",\n  \"password\": \"wrongpassword\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"错误密码 - 返回401\", function () { pm.response.to.have.status(401); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "1.6 获取当前用户信息",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"获取当前用户 - 状态码200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"获取当前用户 - username正确\", function () { var json = pm.response.json(); pm.expect(json.data.username).to.eql(\"zhangsan\"); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "1.7 未登录获取当前用户(预期401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"未登录访问 - 返回401\", function () { pm.response.to.have.status(401); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "1.8 更新个人信息",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"avatar\": \"https://api.dicebear.com/7.x/avataaars/svg?seed=zhangsan_new\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"更新个人信息 - 状态码200\", function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
